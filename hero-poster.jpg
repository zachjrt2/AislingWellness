<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <rect width="1920" height="1080" fill="#0e1a0c"/>
  <rect x="0" y="0" width="1920" height="1080" fill="#111e0f"/>
  <!-- Subtle botanical pattern -->
  <circle cx="960" cy="540" r="600" fill="none" stroke="#1a2e18" stroke-width="1" opacity="0.4"/>
  <circle cx="960" cy="540" r="400" fill="none" stroke="#1a2e18" stroke-width="1" opacity="0.3"/>
  <circle cx="960" cy="540" r="200" fill="none" stroke="#2a3e28" stroke-width="1" opacity="0.5"/>
  <!-- Brand mark -->
  <text x="960" y="580" font-family="Georgia, serif" font-size="120" font-weight="300" fill="#c8b97a" opacity="0.12" text-anchor="middle" font-style="italic">Aisling</text>
</svg>
